# ============================================================================
# RAMPART Integration Test Environment File Example
# ============================================================================
#
# Copy this file to tests/integration/.env.local and fill in the values.
# .env.local is gitignored.
#
# MOST USERS ONLY NEED 2 VARIABLES to run the integration tests:
#
#   RAMPART_TEST_OPENAI_ENDPOINT="https://xxxxx.openai.azure.com/openai/v1"
#   RAMPART_TEST_OPENAI_MODEL="gpt-4o-mini"
#
# These work with OpenAI, Azure OpenAI, and any other OpenAI-compatible
# endpoint.
#
# If you are authenticating to Azure via Entra (e.g. `az login` locally,
# managed or workload identity in CI), leave RAMPART_TEST_OPENAI_KEY
# unset — DefaultAzureCredential is used automatically.
#
# ============================================================================


###################################
# RAMPART INTEGRATION TEST SECRETS
###################################

# Required: OpenAI-compatible endpoint URL.
# For Azure OpenAI use the new format with /openai/v1:
#   https://xxxxx.openai.azure.com/openai/v1
# For OpenAI:
#   https://api.openai.com/v1
RAMPART_TEST_OPENAI_ENDPOINT=""

# Required: Model identifier. With the new Azure OpenAI /openai/v1
# URL format, put your *deployment name* here directly — Azure routes
# by model name in the URL path, so a separate deployment variable
# is not needed. For OpenAI, use the standard model id (e.g. "gpt-4o").
RAMPART_TEST_OPENAI_MODEL=""

# Optional: API key. Leave empty for Azure endpoints that authenticate
# via Entra ID.
RAMPART_TEST_OPENAI_KEY=""


# ============================================================================
# Note: RAMPART uses PyRIT under the hood. The session-scoped conftest
# passes this file to pyrit.setup.initialize_pyrit_async(env_files=...),
# which loads the variables via python-dotenv before any test runs. In CI
# (ADO, GitHub Actions) this file is absent and pipeline-injected env vars
# are used directly — no code branching required.
# ============================================================================

